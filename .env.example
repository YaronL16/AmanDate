POSTGRES_DB=amandate
POSTGRES_USER=amandate
POSTGRES_PASSWORD=amandate
POSTGRES_PORT=5432

API_PORT=8000

APP_ENV=development

# DATABASE_URL is constructed automatically in docker-compose for the api container.
# For local development outside Docker, you can set it explicitly, e.g.:
# DATABASE_URL=postgresql+psycopg2://amandate:amandate@localhost:5432/amandate

